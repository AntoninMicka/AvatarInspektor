{
  "manifest_version": 3,
  "name": "Avatar Inspector",
  "version": "0.1.0",
  "description": "Analyze profile images and explain signs of reuse or recompression.",
  "permissions": [
    "contextMenus",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "node_modules/exifr/dist/full.umd.js",
      "background.js"
    ],
    "service_worker": "background-worker.js"
  },
  "action": {
    "default_title": "Avatar Inspector",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "rules.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
