{
  "manifest_version": 2,
  "name": "Avatar Inspector",
  "version": "0.1.0",
  "description": "Local profile trust checklist with manual notes and profile-photo heuristics.",
  "permissions": [
    "contextMenus",
    "storage",
    "tabs",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "node_modules/exifr/dist/full.umd.js",
      "background.js"
    ]
  },
  "browser_action": {
    "default_title": "Avatar Inspector",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    "rules.json"
  ]
}
